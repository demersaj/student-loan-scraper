NELNET_USERNAME=
NELNET_PASSWORD=

# Optional: paste the My Loans URL from the browser after you open it manually once.
# MY_LOANS_URL=https://nelnet.studentaid.gov/...

# Google Sheets (optional): service account JSON path; share the sheet with the SA email as Editor.
# https://cloud.google.com/iam/docs/service-accounts
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GOOGLE_SHEETS_SPREADSHEET_ID=1BtuWfsC-pFMX2cKdxUOuPCd1gp8XLVhnGuhgmzVXYoY
# GOOGLE_SHEETS_TAB=Data

# Optional: auto-read email OTP via IMAP (use an app password, not your normal login)
# Gmail: https://myaccount.google.com/apppasswords
# MFA_IMAP_HOST=imap.gmail.com
# MFA_IMAP_USER=you@gmail.com
# MFA_IMAP_PASSWORD=xxxx xxxx xxxx xxxx
# MFA_IMAP_MAILBOX=INBOX
# MFA_IMAP_MAX_WAIT_MS=300000
# MFA_IMAP_DEBUG=1
# Optional: substring of From address or display name (default nelnet).
# MFA_EMAIL_FROM_CONTAINS=nelnetnoreply
# MFA_EMAIL_SUBJECT_CONTAINS=code
