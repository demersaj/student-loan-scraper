NELNET_USERNAME=
NELNET_PASSWORD=

# Optional: auto-read email OTP via IMAP (use an app password, not your normal login)
# Gmail: https://myaccount.google.com/apppasswords
# MFA_IMAP_HOST=imap.gmail.com
# MFA_IMAP_USER=you@gmail.com
# MFA_IMAP_PASSWORD=xxxx xxxx xxxx xxxx
# MFA_IMAP_MAILBOX=INBOX
# Optional: substring of From address (default nelnet — matches NelnetNoReply@… and @nelnet…).
# MFA_EMAIL_FROM_CONTAINS=nelnetnoreply
# MFA_EMAIL_SUBJECT_CONTAINS=code
